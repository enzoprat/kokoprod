---
import HeroMockupGrid from './HeroMockupGrid.astro';
---
<section class="hero" id="top">
  <div class="container-koko hero-grid">
    <!-- Colonne texte (gauche desktop, full mobile) -->
    <div class="hero-text">
      <img
        src="/logo-white.png"
        alt=""
        class="hero-logo"
        width="120"
        height="90"
        data-reveal
      />

      <div class="meta" data-reveal style="--reveal-delay: 80ms;">
        <span class="dot"></span>
        <span>Première agence d'IA générative</span>
      </div>

      <h1 class="title" data-reveal style="--reveal-delay: 160ms;">
        <span class="line">Koko</span>
        <span class="line"><em class="cursive">Studio</em> AI</span>
      </h1>

      <p class="lede" data-reveal style="--reveal-delay: 120ms;">
        Votre créateur de vidéos en <strong>intelligence artificielle</strong>,
        pour les marques qui veulent raconter sans compromis.
      </p>

      <div class="actions" data-reveal style="--reveal-delay: 220ms;">
        <a href="#contact" class="btn glass-strong glass-sheen">
          <span>Échangeons</span>
          <svg viewBox="0 0 24 24" fill="none" width="18" height="18" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#realisations" class="link-arrow">
          <span>Voir les réalisations</span>
        </a>
      </div>
    </div>

    <!-- Colonne visuelle (droite desktop, sous le texte mobile) -->
    <div class="hero-visual" data-reveal style="--reveal-delay: 300ms;">
      <HeroMockupGrid />
    </div>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span>SCROLL</span>
    <span class="line-v"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding: 120px 0 80px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    align-items: center;
    gap: 48px;
    width: 100%;
  }

  /* La colonne texte a une "safe zone" : aucun visuel ne vient empiéter dessus
     même en cas d'inclinaison de la grappe. */
  .hero-text {
    position: relative;
    z-index: 2;
    max-width: 640px;
  }

  .hero-visual {
    position: relative;
    z-index: 1;
    height: 100%;
    min-height: 540px;
  }

  /* Sous 960px : on empile, le texte reste en haut, le mockup mobile dessous */
  @media (max-width: 960px) {
    .hero {
      min-height: auto;
      padding: 96px 0 64px;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .hero-text { max-width: 100%; text-align: center; margin: 0 auto; }
    .hero-visual { min-height: auto; }
    .meta { justify-content: center; display: inline-flex; }
    .actions { justify-content: center; }
    .scroll-hint { display: none; }
  }

  .hero-logo {
    height: 88px;
    width: auto;
    object-fit: contain;
    display: block;
    margin-bottom: 28px;
    filter: drop-shadow(0 0 24px rgba(217, 168, 247, 0.5));
  }

  @media (max-width: 960px) {
    .hero-logo { margin-left: auto; margin-right: auto; height: 76px; }
  }

  .meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 36px;
  }

  .meta .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--koko-orange);
    box-shadow: 0 0 14px rgba(255, 111, 0, 0.85);
    animation: pulse 2.4s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  .title {
    font-size: clamp(2.6rem, 7vw, 6rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.04em;
    margin: 0 0 32px;
    color: #fff;
  }

  .title .line {
    display: block;
  }

  .lede {
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 560px;
    margin: 0 0 36px;
    line-height: 1.55;
  }
  @media (max-width: 960px) {
    .lede { margin-left: auto; margin-right: auto; }
  }

  .lede strong { color: #fff; font-weight: 500; }

  .actions {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px 16px 32px;
    border-radius: 999px;
    color: #fff;
    font-weight: 500;
    font-size: 0.98rem;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 50px -16px rgba(40, 0, 80, 0.6);
  }
  .btn svg { transition: transform 0.3s ease; }
  .btn:hover svg { transform: translateX(4px); }

  .link-arrow {
    position: relative;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    font-weight: 500;
    padding-bottom: 4px;
  }
  .link-arrow::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.5);
    transform-origin: right;
    transform: scaleX(1);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .link-arrow:hover::after {
    transform-origin: left;
    background: #fff;
  }

  .scroll-hint {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.55);
  }
  .scroll-hint .line-v {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
    animation: scrollLine 2.2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0% { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform: scaleY(1); transform-origin: bottom; }
    100% { transform: scaleY(0); transform-origin: bottom; }
  }
</style>
