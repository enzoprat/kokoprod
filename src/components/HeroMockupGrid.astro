---
/**
 * Hero teaser : grappe de mockups iPhone tiltée à droite du H1.
 * Desktop  : 5 mockups en grille décalée + tilt 3D + parallax léger
 * Mobile   : 1 seul mockup central, plus large, sous le bloc texte
 *
 * Perf : on réutilise des vidéos déjà chargées dans les carousels
 *        → le browser cache, aucun coût supplémentaire de réseau.
 *        Les vidéos sont pause()-ées dès qu'elles sortent du viewport
 *        (cf. scripts/motion.ts).
 */
import PhoneMockup from './PhoneMockup.astro';

// On pioche 5 vidéos qui marchent bien visuellement
const desktopTiles = [
  { videoSrc: '/videos/cartier.mp4', label: 'Cartier' },
  { videoSrc: '/videos/cine-simpson.mp4', label: 'Simpson' },
  { videoSrc: '/videos/bpm-race.mp4', label: 'BPM Race' },
  { videoSrc: '/videos/cine-shrek.mp4', label: 'Shrek' },
  { videoSrc: '/videos/coronagym.mp4', label: 'Coronagym' },
];

// Sur mobile : vidéo dédiée "hero-mobile" (= tests.mp4 fourni par le client),
// conçue spécifiquement pour ce slot. Plus pertinent qu'un échantillon des
// carousels qu'on retrouve plus bas dans la page.
const mobileTile = {
  videoSrc: '/videos/hero-mobile.mp4',
  label: 'Koko Studio AI',
};
---

<!-- Desktop grid -->
<div class="grid-wrap" aria-hidden="true">
  <div class="grid">
    {desktopTiles.map((t, i) => (
      <div class={`tile tile-${i + 1}`}>
        <PhoneMockup videoSrc={t.videoSrc} label={t.label} />
      </div>
    ))}
  </div>
</div>

<!-- Mobile single mockup (cliquable → fullscreen) -->
<div class="mobile-tile">
  <PhoneMockup videoSrc={mobileTile.videoSrc} label={mobileTile.label} />
</div>

<style>
  /* ============================
     Desktop : grappe 3D inclinée
     ============================ */
  .grid-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 540px;
    perspective: 1400px;
    pointer-events: none;
  }

  .grid {
    position: absolute;
    inset: 0;
    transform: rotateY(-14deg) rotateX(6deg) rotateZ(-3deg);
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Chaque tile a son scale + position pour un effet "grappe" éditoriale.
     Les variables :hover et :focus n'ont aucun effet ici (pointer-events:none),
     mais on garde la composition propre. */
  .tile {
    position: absolute;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    filter: drop-shadow(0 30px 50px rgba(40, 0, 80, 0.35));
  }

  .tile-1 { /* en haut, plus loin */
    top: 0;
    right: 26%;
    transform: scale(0.78) translateZ(-40px);
    opacity: 0.85;
  }
  .tile-2 { /* hero central, plus grand */
    top: 8%;
    right: 0;
    transform: scale(1.05) translateZ(60px);
    z-index: 3;
  }
  .tile-3 { /* milieu gauche, moyen */
    top: 38%;
    right: 48%;
    transform: scale(0.88) translateZ(20px);
    z-index: 2;
  }
  .tile-4 { /* bas droit */
    bottom: 4%;
    right: 12%;
    transform: scale(0.95) translateZ(40px);
    z-index: 2;
  }
  .tile-5 { /* bas gauche, le plus discret */
    bottom: 18%;
    right: 56%;
    transform: scale(0.7) translateZ(-30px);
    opacity: 0.75;
  }

  /* ============================
     Mobile single mockup
     ============================ */
  .mobile-tile {
    display: none;
  }

  /* Affichage : à partir de ~960px on garde la grappe,
     en dessous on passe au mockup unique mobile. */
  @media (max-width: 960px) {
    .grid-wrap { display: none; }
    .mobile-tile {
      display: flex;
      justify-content: center;
      margin: 48px auto 0;
      filter: drop-shadow(0 30px 60px rgba(40, 0, 80, 0.45));
      transform: rotate(-3deg);
    }
    .mobile-tile :global(.phone) {
      width: 220px !important;
    }
  }

  @media (max-width: 480px) {
    .mobile-tile :global(.phone) {
      width: 200px !important;
    }
  }
</style>
