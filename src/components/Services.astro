---
const services = [
  {
    num: '01',
    title: 'Hybride',
    sub: 'Réel filmé x IA',
    text: "Le format hybride part d'un élément réel : un lieu, un produit, un objet ou une scène. L'IA vient ensuite enrichir l'image avec une atmosphère, un décor ou un effet impossible à créer facilement en réel.",
  },
  {
    num: '02',
    title: 'Full IA',
    sub: '100% génératif',
    text: "Le full IA permet de créer une vidéo entièrement à partir d'une idée. C'est le bon format quand on veut imaginer un lieu, une scène ou un univers qui n'existe pas encore, avec une direction artistique totalement libre. On part d'une idée, et l'IA construit tout l'univers autour.",
  },
];
---

<section class="services" id="services">
  <div class="container-koko">
    <header class="head" data-reveal>
      <span class="eyebrow">Approches</span>
      <h2>Deux manières de raconter, une seule exigence.</h2>
    </header>

    <div class="grid">
      {services.map((s, i) => (
        <article class="card glass glass-sheen" data-reveal style={`--reveal-delay: ${i * 120}ms;`}>
          <div class="card-head">
            <span class="num">{s.num}</span>
            <span class="rule"></span>
            <span class="sub">{s.sub}</span>
          </div>

          <h3>{s.title}</h3>

          <p class="text">{s.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    padding: 100px 0 60px;
  }

  .head {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 64px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 18px;
  }

  .head h2 {
    margin: 0;
    font-size: clamp(2rem, 4.4vw, 3.4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #fff;
    line-height: 1.05;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
  }

  .card {
    padding: 44px 40px 40px;
    border-radius: 28px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      0 32px 60px -22px rgba(40, 0, 80, 0.6);
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 28px;
  }

  .num {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.85);
  }

  .rule {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
  }

  .sub {
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.04em;
  }

  .card h3 {
    margin: 0 0 20px;
    font-size: clamp(1.8rem, 2.6vw, 2.4rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .text {
    margin: 0 0 28px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    font-size: 1rem;
  }

  .bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
  }

  .bullets li {
    padding: 12px 0;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.85);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .bullets li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 10px rgba(255, 255, 255, 0.7);
    flex-shrink: 0;
  }

  .bullets li:last-child {
    border-bottom: none;
  }
</style>
