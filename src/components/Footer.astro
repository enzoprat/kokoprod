---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-koko">
    <div class="meta">
      <div class="brand">
        <img src="/logo.png" alt="" width="36" height="36" />
        <span>Koko <span class="dot">Studio Ai</span></span>
      </div>
      <div class="links">
        <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:hello@kokostudio.ai">Email</a>
      </div>
      <p class="legal">© {year} Koko Studio Ai — Paris</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 80px;
    padding: 48px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.25) 100%);
    position: relative;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    flex-wrap: wrap;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
    color: #fff;
    font-size: 1rem;
  }

  .brand img {
    filter: drop-shadow(0 0 8px rgba(217, 168, 247, 0.5));
  }

  .brand .dot {
    color: #D9A8F7;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .links {
    display: flex;
    gap: 24px;
  }

  .links a {
    color: rgba(255, 255, 255, 0.65);
    transition: color 0.2s ease;
  }

  .links a:hover { color: #fff; }

  .legal { margin: 0; }
</style>
