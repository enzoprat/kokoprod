---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container-koko">
    <div class="meta">
      <div class="brand">
        <img
          src="/logo-white.png"
          alt="Koko Studio AI"
          class="brand-icon"
          width="48"
          height="36"
        />
      </div>
      <div class="links">
        <a href="https://www.instagram.com/alexandre.baret" target="_blank" rel="noopener noreferrer">Instagram</a>
        <a href="https://www.linkedin.com/company/koko-productions-ai-studio/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="mailto:hello@kokostudio.ai">Email</a>
      </div>
      <p class="legal">© {year} Koko Studio AI</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 80px;
    padding: 48px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.25) 100%);
    position: relative;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    flex-wrap: wrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
  }

  .brand-icon {
    height: 36px;
    width: auto;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 0 10px rgba(217, 168, 247, 0.4));
  }

  .links {
    display: flex;
    gap: 24px;
  }

  .links a {
    color: rgba(255, 255, 255, 0.65);
    transition: color 0.2s ease;
  }

  .links a:hover { color: #fff; }

  .legal { margin: 0; }
</style>
