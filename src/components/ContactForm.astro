---
const subjects = [
  'Discutons d’un projet',
  'Demande de devis',
  'Collaboration créative',
  'Autre',
];
---

<section class="contact" id="contact">
  <div class="container-koko">
    <div class="wrap glass glass-sheen" data-reveal>
      <div class="head">
        <span class="eyebrow">Contact</span>
        <h2>
          Un brief, une idée,<br />
          <em class="cursive">une obsession ?</em>
        </h2>
        <p class="sub">
          Remplissez ces quelques champs, on revient vers vous sous 48h.
        </p>
      </div>

      <form
        class="form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
      >
        <!-- Web3Forms : clé publique côté front, OK pour ce service -->
        <input
          type="hidden"
          name="access_key"
          value="d8545e3b-b564-46ad-ae30-95c4b557c578"
        />
        <input
          type="hidden"
          name="subject"
          value="Nouveau brief Koko Studio AI"
        />
        <input
          type="hidden"
          name="from_name"
          value="Koko Studio AI · site web"
        />
        <!-- Honeypot anti-spam (laisser vide) -->
        <input
          type="checkbox"
          name="botcheck"
          class="botcheck"
          tabindex="-1"
          autocomplete="off"
        />

        <div class="row">
          <label class="field">
            <span class="label">Nom</span>
            <input type="text" name="name" required autocomplete="name" placeholder="Martin Dupont" />
          </label>

          <label class="field">
            <span class="label">Email</span>
            <input type="email" name="email" required autocomplete="email" placeholder="martin.dupont@gmail.com" />
          </label>
        </div>

        <div class="row">
          <label class="field">
            <span class="label">Marque / Maison</span>
            <input type="text" name="brand" autocomplete="organization" placeholder="Optionnel" />
          </label>

          <label class="field">
            <span class="label">Sujet</span>
            <div class="select-wrap">
              <select name="sujet" required>
                {subjects.map((s) => (
                  <option value={s}>{s}</option>
                ))}
              </select>
              <svg class="chev" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </label>
        </div>

        <label class="field full">
          <span class="label">Votre brief</span>
          <textarea
            name="message"
            rows="5"
            required
            placeholder="Quelques mots sur votre projet, votre univers, votre échéance…"
          ></textarea>
        </label>

        <div class="actions">
          <button type="submit" class="submit glass-strong glass-sheen" data-state="idle">
            <span class="btn-label">Envoyer</span>
            <span class="btn-spinner" aria-hidden="true"></span>
            <svg class="btn-arrow" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <svg class="btn-check" viewBox="0 0 24 24" width="20" height="20" fill="none" aria-hidden="true">
              <path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="alt">
            Ou simplement&nbsp;:
            <a href="mailto:hello@kokostudio.ai">hello@kokostudio.ai</a>
          </p>
        </div>

        <p class="form-msg" role="status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>('#contact form');
  if (form) {
    const btn = form.querySelector<HTMLButtonElement>('button[type=submit]')!;
    const msg = form.querySelector<HTMLElement>('.form-msg')!;
    const label = btn.querySelector<HTMLElement>('.btn-label')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot : si rempli = bot, on simule un succès silencieux
      const honeypot = form.querySelector<HTMLInputElement>('input[name=botcheck]');
      if (honeypot?.checked) {
        msg.textContent = 'Message envoyé.';
        msg.dataset.state = 'success';
        return;
      }

      btn.dataset.state = 'loading';
      btn.disabled = true;
      label.textContent = 'Envoi…';
      msg.textContent = '';
      msg.dataset.state = '';

      try {
        const data = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        });
        const json = await res.json();

        if (res.ok && json.success) {
          btn.dataset.state = 'success';
          label.textContent = 'Envoyé';
          msg.textContent = "Merci, on revient vers vous sous 48h.";
          msg.dataset.state = 'success';
          form.reset();
          // On laisse l'état "envoyé" visible quelques secondes
          setTimeout(() => {
            btn.dataset.state = 'idle';
            btn.disabled = false;
            label.textContent = 'Envoyer';
          }, 4000);
        } else {
          throw new Error(json.message || 'Erreur inattendue');
        }
      } catch (err) {
        btn.dataset.state = 'error';
        btn.disabled = false;
        label.textContent = 'Réessayer';
        msg.textContent =
          "Impossible d'envoyer pour le moment. Écrivez-nous directement à hello@kokostudio.ai.";
        msg.dataset.state = 'error';
      }
    });
  }
</script>

<style>
  .contact {
    padding: 80px 0 40px;
  }

  .wrap {
    max-width: 920px;
    margin: 0 auto;
    padding: 56px 56px 48px;
    border-radius: 32px;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .wrap { padding: 36px 24px 32px; border-radius: 24px; }
  }

  .head {
    text-align: center;
    margin-bottom: 48px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 18px;
  }

  .head h2 {
    margin: 0 0 14px;
    font-size: clamp(2rem, 4.4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #fff;
    line-height: 1.05;
  }

  .sub {
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.75);
    font-size: 1rem;
    max-width: 460px;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    padding-left: 4px;
  }

  .field input,
  .field textarea,
  .field select {
    width: 100%;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 14px;
    color: #fff;
    font-family: inherit;
    font-size: 0.98rem;
    line-height: 1.4;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.25s ease;
    outline: none;
  }

  .field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .field input:hover,
  .field textarea:hover,
  .field select:hover {
    background: rgba(255, 255, 255, 0.11);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    border-color: var(--koko-orange);
    background: rgba(255, 255, 255, 0.14);
    box-shadow: 0 0 0 4px rgba(255, 111, 0, 0.18);
  }

  .select-wrap {
    position: relative;
  }

  .select-wrap select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 44px;
    cursor: pointer;
  }

  .select-wrap select option {
    background: #5A009E;
    color: #fff;
  }

  .chev {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.7);
    pointer-events: none;
  }

  .actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .submit {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    border-radius: 999px;
    color: #fff;
    font-weight: 500;
    font-size: 0.98rem;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
                box-shadow 0.3s ease,
                background 0.4s ease;
    min-width: 160px;
    justify-content: center;
  }

  .submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 22px 48px -16px rgba(40, 0, 80, 0.6);
  }

  .submit:disabled {
    cursor: wait;
    opacity: 0.95;
  }

  .submit .btn-arrow { transition: transform 0.3s ease; }
  .submit:hover:not(:disabled) .btn-arrow { transform: translateX(4px); }

  /* États du bouton */
  .btn-spinner,
  .btn-check {
    display: none;
  }

  .submit[data-state="loading"] .btn-arrow { display: none; }
  .submit[data-state="loading"] .btn-spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin-btn 0.7s linear infinite;
  }

  .submit[data-state="success"] {
    background: linear-gradient(135deg, rgba(120, 220, 150, 0.4), rgba(80, 200, 130, 0.5));
  }
  .submit[data-state="success"] .btn-arrow { display: none; }
  .submit[data-state="success"] .btn-check {
    display: inline-block;
    animation: pop-check 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .submit[data-state="error"] {
    background: linear-gradient(135deg, rgba(255, 130, 130, 0.4), rgba(220, 80, 80, 0.5));
  }

  @keyframes spin-btn {
    to { transform: rotate(360deg); }
  }

  @keyframes pop-check {
    0% { transform: scale(0.4); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* Honeypot anti-bot : visuellement et fonctionnellement caché aux humains */
  .botcheck {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  /* Message de feedback sous le bouton */
  .form-msg {
    width: 100%;
    margin: 18px 0 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.75);
    min-height: 1.2em;
    transition: color 0.3s ease;
  }
  .form-msg[data-state="success"] { color: #c5f5d8; }
  .form-msg[data-state="error"] { color: #ffc4c4; }

  .alt {
    margin: 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .alt a {
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    transition: border-color 0.2s ease;
  }

  .alt a:hover {
    border-color: #fff;
  }
</style>
