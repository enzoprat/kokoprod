---
const subjects = [
  'Discutons d’un projet',
  'Demande de devis',
  'Collaboration créative',
  'Autre',
];
---

<section class="contact" id="contact">
  <div class="container-koko">
    <div class="wrap glass glass-sheen" data-reveal>
      <div class="head">
        <span class="eyebrow">— Contact</span>
        <h2>
          Un brief, une idée,<br />
          <em class="cursive">une obsession ?</em>
        </h2>
        <p class="sub">
          Remplissez ces quelques champs — on revient vers vous sous 48h.
        </p>
      </div>

      <form
        class="form"
        action="https://formspree.io/f/your-form-id"
        method="POST"
        novalidate
      >
        <div class="row">
          <label class="field">
            <span class="label">Nom</span>
            <input type="text" name="name" required autocomplete="name" placeholder="Alex Dupont" />
          </label>

          <label class="field">
            <span class="label">Email</span>
            <input type="email" name="email" required autocomplete="email" placeholder="alex@maison.com" />
          </label>
        </div>

        <div class="row">
          <label class="field">
            <span class="label">Marque / Maison</span>
            <input type="text" name="brand" autocomplete="organization" placeholder="Optionnel" />
          </label>

          <label class="field">
            <span class="label">Sujet</span>
            <div class="select-wrap">
              <select name="subject" required>
                {subjects.map((s) => (
                  <option value={s}>{s}</option>
                ))}
              </select>
              <svg class="chev" viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </label>
        </div>

        <label class="field full">
          <span class="label">Votre brief</span>
          <textarea
            name="message"
            rows="5"
            required
            placeholder="Quelques mots sur votre projet, votre univers, votre échéance…"
          ></textarea>
        </label>

        <div class="actions">
          <button type="submit" class="submit glass-strong glass-sheen">
            <span>Envoyer</span>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="alt">
            Ou simplement&nbsp;:
            <a href="mailto:hello@kokoprod.fr">hello@kokoprod.fr</a>
          </p>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 80px 0 40px;
  }

  .wrap {
    max-width: 920px;
    margin: 0 auto;
    padding: 56px 56px 48px;
    border-radius: 32px;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .wrap { padding: 36px 24px 32px; border-radius: 24px; }
  }

  .head {
    text-align: center;
    margin-bottom: 48px;
  }

  .eyebrow {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 18px;
  }

  .head h2 {
    margin: 0 0 14px;
    font-size: clamp(2rem, 4.4vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #fff;
    line-height: 1.05;
  }

  .sub {
    margin: 0 auto;
    color: rgba(255, 255, 255, 0.75);
    font-size: 1rem;
    max-width: 460px;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  @media (max-width: 640px) {
    .row { grid-template-columns: 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    padding-left: 4px;
  }

  .field input,
  .field textarea,
  .field select {
    width: 100%;
    padding: 14px 18px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 14px;
    color: #fff;
    font-family: inherit;
    font-size: 0.98rem;
    line-height: 1.4;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.25s ease;
    outline: none;
  }

  .field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .field input:hover,
  .field textarea:hover,
  .field select:hover {
    background: rgba(255, 255, 255, 0.11);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    border-color: rgba(255, 255, 255, 0.55);
    background: rgba(255, 255, 255, 0.14);
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.08);
  }

  .select-wrap {
    position: relative;
  }

  .select-wrap select {
    appearance: none;
    -webkit-appearance: none;
    padding-right: 44px;
    cursor: pointer;
  }

  .select-wrap select option {
    background: #5A009E;
    color: #fff;
  }

  .chev {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.7);
    pointer-events: none;
  }

  .actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 12px;
    flex-wrap: wrap;
  }

  .submit {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    border-radius: 999px;
    color: #fff;
    font-weight: 500;
    font-size: 0.98rem;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease;
  }

  .submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 48px -16px rgba(40, 0, 80, 0.6);
  }

  .submit svg { transition: transform 0.3s ease; }
  .submit:hover svg { transform: translateX(4px); }

  .alt {
    margin: 0;
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .alt a {
    color: #fff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.4);
    transition: border-color 0.2s ease;
  }

  .alt a:hover {
    border-color: #fff;
  }
</style>
